{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "envFile": "${workspaceFolder}/backend/.env",
      "args": [
        "src.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--log-config",
        "logging_config.yaml",
        "--reload"
      ],
      "jinja": true,
      "justMyCode": false
    },
    {
        "name": "Frontend Portal",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder}/frontend",
        "console": "integratedTerminal",
        "runtimeExecutable": "npm",
        "runtimeArgs": [
            "run",
            "dev",
            "--",
            "--open"
        ],
        "skipFiles": [
            "node_modules/**"
        ]
    },
    {
        "name": "Python: Current File",
        "type": "debugpy",
        "request": "launch",
        "program": "${file}",
        "justMyCode": true
    }
  ]
}
